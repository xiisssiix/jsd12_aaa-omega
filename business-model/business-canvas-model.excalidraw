      "versionNonce": 470018255,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775058856368,
      "link": null,
      "locked": false,
      "text": "• บ้านพักอาศัย (B2C): \nเจ้าของบ้านที่ค่าไฟ \n3,000 บาทขึ้นไป\n\n• โรงงาน/อาคาร (B2B): \nผู้ใช้ไฟมากในช่วงกลางวัน\n\n\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "• บ้านพักอาศัย (B2C): \nเจ้าของบ้านที่ค่าไฟ \n3,000 บาทขึ้นไป\n\n• โรงงาน/อาคาร (B2B): \nผู้ใช้ไฟมากในช่วงกลางวัน\n\n\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "la2ANPCuVgHU6FhwAsJWM",
      "type": "text",
      "x": 1014.5952380952382,
      "y": 133.7619047619047,
      "width": 212.13232421875,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffec99",
